# ============================================================
# Nexus / 星策 — 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# ---------- LLM Provider Keys ----------
# 主 Provider: Moonshot / Kimi
MOONSHOT_API_KEY=

# 备用 Provider: 通义千问 (DashScope)
DASHSCOPE_API_KEY=

# ---------- Model 选择 (可选，有默认值) ----------
# NEXUS_PRIMARY_MODEL=kimi-k2-0711-preview
# NEXUS_PRIMARY_BASE_URL=https://api.moonshot.cn/v1
# NEXUS_FALLBACK_MODEL=qwen-max

# ---------- 飞书 / Feishu ----------
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
# FEISHU_BASE_URL=https://open.feishu.cn/open-apis

# ---------- Server ----------
NEXUS_HOST=127.0.0.1
NEXUS_PORT=8000

# ---------- Audio Worker (可选) ----------
# 主后端默认使用本地 SenseVoice；如需独立 GPU worker，可覆盖为：
# NEXUS_AUDIO_BACKEND=sensevoice_remote
# NEXUS_AUDIO_BASE_URL=http://127.0.0.1:8010
# NEXUS_AUDIO_DEVICE=cuda
# NEXUS_AUDIO_MODEL_DIR=./models/sensevoice/SenseVoiceSmall

# ---------- Paths (可选，默认相对于项目根目录) ----------
# NEXUS_CONFIG_PATH=./config/app.yaml
# NEXUS_SCHEDULER_CONFIG_PATH=./config/scheduler.yaml
# NEXUS_VAULT_ROOT=./vault

# ---------- Web Search (可选) ----------
# GOOGLE_API_KEY=
# GOOGLE_SEARCH_ENGINE_ID=
