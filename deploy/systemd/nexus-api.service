[Unit]
Description=Nexus API Backend
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/USER/nexus
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/USER/miniconda3/envs/nexus/bin/python -m nexus serve --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
